---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PartyInfobox from "../../components/PartyInfobox.astro";
import SourceList from "../../components/SourceList.astro";
import PartyText from "../../components/PartyText.astro";
import { withBase } from "../../lib/paths";

export async function getStaticPaths() {
  const parties = await getCollection("parties");
  return parties.map((entry) => ({
    params: { id: entry.id },
    props: { entry }
  }));
}

const { entry } = Astro.props;
const party = entry.data;
const sourceMap = new Map(
  party.sources.map((source: any, index: number) => [source.id, index + 1])
);

function sourceLinks(ids: string[] = []) {
  return ids
    .filter((id) => sourceMap.has(id))
    .map((id) => ({ id, label: sourceMap.get(id) }));
}

function formatLifeDates(leader: any): string | null {
  const hasBirth = typeof leader.birthYear === "number";
  const hasDeath = typeof leader.deathYear === "number";

  if (hasBirth && hasDeath) {
    return `(${leader.birthYear}–${leader.deathYear})`;
  }
  if (hasBirth) {
    return `(b. ${leader.birthYear})`;
  }
  if (hasDeath) {
    return `(d. ${leader.deathYear})`;
  }
  return null;
}

function formatInteger(value: unknown): string {
  return typeof value === "number"
    ? new Intl.NumberFormat("en-US").format(value)
    : "—";
}

function formatPercentage(value: unknown): string {
  return typeof value === "number" ? `${value}%` : "—";
}

const parliamentaryResults = party.electionResults?.parliamentary ?? [];
const presidentialResults = party.electionResults?.presidential ?? [];
---

<BaseLayout
  title={`${party.name.english} — Political Parties Database`}
  description={party.summary}
>
  <nav class="breadcrumbs" aria-label="Breadcrumb">
    <a href={withBase("/")}>Home</a>
    <span>›</span>
    <a href={withBase("/parties/")}>Parties</a>
    <span>›</span>
    <span>{party.name.english}</span>
  </nav>

  <header class="party-header">
    <div>
      <p class="eyebrow">{party.country.name}</p>
      <h1>{party.name.english}</h1>
      {party.name.native.length > 0 && (
        <p class="native-heading">{party.name.native.join(" · ")}</p>
      )}
      {party.name.abbreviation && (
        <p class="abbreviation">{party.name.abbreviation}</p>
      )}
    </div>
  </header>

  <div class="article-layout">
    <article data-pagefind-body>
      <section class="party-summary">
        <p>
  <PartyText text={party.summary} />
</p>
      </section>

      {party.history.formation && (
        <section>
          <h2>History</h2>
          <p>
            <PartyText text={party.history.formation} />
            {sourceLinks(party.history.formationSourceIds).map((source) => (
              <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
            ))}
          </p>
        </section>
      )}

      {(party.ideology.labels.length > 0 || party.ideology.position) && (
        <section>
          <h2>Ideology and political position</h2>
          {party.ideology.labels.length > 0 && (
            <ul class="definition-list">
              {party.ideology.labels.map((item: any) => (
                <li>
                  <strong>{item.name}</strong>
                  {item.note && <> — {item.note}</>}
                  {sourceLinks(item.sourceIds).map((source) => (
                    <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
                  ))}
                </li>
              ))}
            </ul>
          )}
          {party.ideology.position && (
            <p>
              <strong>Position:</strong> {party.ideology.position.label}
              {party.ideology.position.note && <> — {party.ideology.position.note}</>}
              {sourceLinks(party.ideology.position.sourceIds).map((source) => (
                <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
              ))}
            </p>
          )}
        </section>
      )}

      {party.leadership.length > 0 && (
        <section>
          <h2>Leadership</h2>
          <div class="table-wrap">
            <table>
              <thead>
                <tr>
                  <th>Office</th>
                  <th>Person</th>
                  <th>Term</th>
                  <th>References</th>
                </tr>
              </thead>
              <tbody>
                {party.leadership.map((leader: any) => (
                  <tr>
                    <td>{leader.title}</td>
                    <td>
                      {leader.person}
                      {formatLifeDates(leader) && (
                        <><br /><small class="life-dates">{formatLifeDates(leader)}</small></>
                      )}
                    </td>
                    <td>
                      {leader.since ?? "Unknown"}{leader.until ? `–${leader.until}` : ""}
                      {leader.note && <><br /><small>{leader.note}</small></>}
                    </td>
                    <td class="references-cell">
                      {sourceLinks(leader.sourceIds).map((source) => (
                        <><a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a>{" "}</>
                      ))}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </section>
      )}

      {party.governmentStatus && (
        <section>
          <h2>Political status</h2>
          <p>
            <strong>{party.governmentStatus.label.replace("-", " ")}</strong>
            {party.governmentStatus.since && <> since {party.governmentStatus.since}</>}
            {party.governmentStatus.description && <>. {party.governmentStatus.description}</>}
            {sourceLinks(party.governmentStatus.sourceIds).map((source) => (
              <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
            ))}
          </p>
        </section>
      )}

      {party.internationalAffiliations.length > 0 && (
        <section>
          <h2>International affiliations</h2>
          <ul>
            {party.internationalAffiliations.map((item: any) => (
              <li>
                {item.name}{item.status ? ` — ${item.status}` : ""}
                {item.since ? ` (since ${item.since})` : ""}
                {sourceLinks(item.sourceIds).map((source) => (
                  <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
                ))}
              </li>
            ))}
          </ul>
        </section>
      )}

      {(parliamentaryResults.length > 0 || presidentialResults.length > 0) && (
        <section>
          <h2>Election results</h2>

          {parliamentaryResults.length > 0 && (
            <>
              <h3>Parliamentary elections</h3>
              <div class="table-wrap">
                <table class="election-results-table">
                  <thead>
                    <tr>
                      <th>Year</th>
                      <th>List leader</th>
                      <th>Votes</th>
                      <th>%</th>
                      <th>Seats</th>
                      <th>Outcome</th>
                      <th>References</th>
                    </tr>
                  </thead>
                  <tbody>
                    {parliamentaryResults.map((result: any) => (
                      <tr>
                        <td>{result.year}</td>
                        <td>{result.listLeader ?? "—"}</td>
                        <td class="numeric-cell">{formatInteger(result.votes)}</td>
                        <td class="numeric-cell">{formatPercentage(result.percentage)}</td>
                        <td class="numeric-cell">{formatInteger(result.seats)}</td>
                        <td>{result.outcome ?? "—"}</td>
                        <td class="references-cell">
                          {sourceLinks(result.sourceIds).map((source) => (
                            <><a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a>{" "}</>
                          ))}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}

          {presidentialResults.length > 0 && (
            <>
              <h3>Presidential elections</h3>
              <div class="table-wrap">
                <table class="election-results-table">
                  <thead>
                    <tr>
                      <th>Year</th>
                      <th>Candidate</th>
                      <th>First-round votes</th>
                      <th>%</th>
                      <th>Second-round votes</th>
                      <th>%</th>
                      <th>Outcome</th>
                      <th>References</th>
                    </tr>
                  </thead>
                  <tbody>
                    {presidentialResults.map((result: any) => (
                      <tr>
                        <td>{result.year}</td>
                        <td>{result.candidate}</td>
                        <td class="numeric-cell">{formatInteger(result.firstRoundVotes)}</td>
                        <td class="numeric-cell">{formatPercentage(result.firstRoundPercentage)}</td>
                        <td class="numeric-cell">{formatInteger(result.secondRoundVotes)}</td>
                        <td class="numeric-cell">{formatPercentage(result.secondRoundPercentage)}</td>
                        <td>{result.outcome ?? "—"}</td>
                        <td class="references-cell">
                          {sourceLinks(result.sourceIds).map((source) => (
                            <><a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a>{" "}</>
                          ))}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            </>
          )}
        </section>
      )}

      {(party.links.website || party.links.facebook || party.links.x || party.links.instagram || party.links.youtube || party.links.other.length > 0) && (
        <section>
          <h2>External links</h2>
          <ul>
            {party.links.website && <li><a href={party.links.website}>Official website</a></li>}
            {party.links.facebook && <li><a href={party.links.facebook}>Facebook</a></li>}
            {party.links.x && <li><a href={party.links.x}>X</a></li>}
            {party.links.instagram && <li><a href={party.links.instagram}>Instagram</a></li>}
            {party.links.youtube && <li><a href={party.links.youtube}>YouTube</a></li>}
            {party.links.other.map((link: any) => <li><a href={link.url}>{link.label}</a></li>)}
          </ul>
        </section>
      )}

      <section>
        <h2>Sources</h2>
        <SourceList sources={party.sources} />
      </section>

      <section class="editorial-note">
        <h2>Editorial status</h2>
        <p>
          Completeness: <strong>{party.editorial.completeness}</strong>.
          {party.editorial.needsReview ? " This entry is marked for review." : " No review flag is set."}
        </p>
        {party.editorial.note && <p>{party.editorial.note}</p>}
      </section>
    </article>

    <PartyInfobox party={party} />
  </div>
</BaseLayout>
