---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import PartyCard from "../components/PartyCard.astro";
import { withBase } from "../lib/paths";

const entries = await getCollection("parties");
const parties = entries
  .map((entry) => ({ entryId: entry.id, ...entry.data }))
  .sort((a, b) => a.name.english.localeCompare(b.name.english));

const countries = new Set(parties.map((party) => party.country.id)).size;
const active = parties.filter((party) => party.status === "active").length;
---

<BaseLayout title="Political Parties Database">
  <section class="hero">
    <p class="eyebrow">Source-based reference project</p>
    <h1>Political Parties Database</h1>
    <p class="lead">
      Structured profiles of political parties, coalitions and historical organisations,
      with explicit source references and editorial status.
    </p>
    <div class="hero-actions">
      <a class="button" href={withBase("/parties/")}>Browse parties</a>
      <a class="button button-secondary" href={withBase("/about/")}>Methodology</a>
    </div>
  </section>

  <section class="stats" aria-label="Database statistics">
    <div><strong>{parties.length}</strong><span>party entries</span></div>
    <div><strong>{countries}</strong><span>countries</span></div>
    <div><strong>{active}</strong><span>active parties</span></div>
  </section>

  <section class="section-heading">
    <div>
      <p class="eyebrow">Recently reviewed</p>
      <h2>Sample entries</h2>
    </div>
    <a href={withBase("/parties/")}>View all →</a>
  </section>

  <div class="card-grid">
    {parties.slice(0, 6).map((party) => (
      <PartyCard party={party} entryId={party.entryId} />
    ))}
  </div>
</BaseLayout>
