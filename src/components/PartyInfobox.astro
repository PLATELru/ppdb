---
import { assetPath, withBase } from "../lib/paths";
import { formatDate, statusLabels } from "../lib/format";

interface Props {
  party: any;
}

const { party } = Astro.props;
const sourceMap = new Map(
  party.sources.map((source: any, index: number) => [source.id, index + 1])
);

function sourceLinks(ids: string[] = []) {
  return ids
    .filter((id) => sourceMap.has(id))
    .map((id) => ({ id, label: sourceMap.get(id) }));
}
---

<aside class="infobox">
  <img class="infobox-logo" src={assetPath(party.logo)} alt={`${party.name.english} logo`} />
  <dl>
    <div>
      <dt>Country</dt>
      <dd><a href={withBase(`/countries/${party.country.id}/`)}>{party.country.name}</a></dd>
    </div>
    <div>
      <dt>Status</dt>
      <dd>{statusLabels[party.status]}</dd>
    </div>
    <div>
      <dt>Founded</dt>
      <dd>
        {formatDate(party.dates.founded.date)}
        {sourceLinks(party.dates.founded.sourceIds).map((source) => (
          <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
        ))}
      </dd>
    </div>
    {party.dates.registered?.date && (
      <div>
        <dt>Registered</dt>
        <dd>
          {formatDate(party.dates.registered.date)}
          {sourceLinks(party.dates.registered.sourceIds).map((source) => (
            <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
          ))}
        </dd>
      </div>
    )}
    {party.dates.dissolved?.date && (
      <div>
        <dt>Dissolved</dt>
        <dd>
          {formatDate(party.dates.dissolved.date)}
          {sourceLinks(party.dates.dissolved.sourceIds).map((source) => (
            <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
          ))}
        </dd>
      </div>
    )}
    {party.ideology.position?.label && (
      <div>
        <dt>Position</dt>
        <dd>{party.ideology.position.label}</dd>
      </div>
    )}
    {party.lastUpdated && (
      <div>
        <dt>Last reviewed</dt>
        <dd>{party.lastUpdated}</dd>
      </div>
    )}
  </dl>
</aside>
