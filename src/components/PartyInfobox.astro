---
import { assetPath, withBase } from "../lib/paths";
import { formatDate, statusLabels } from "../lib/format";

interface Props {
  party: any;
}

const { party } = Astro.props;

const sourceMap = new Map(
  party.sources.map((source: any, index: number) => [source.id, index + 1])
);

function sourceLinks(ids: string[] = []) {
  return ids
    .filter((id) => sourceMap.has(id))
    .map((id) => ({ id, label: sourceMap.get(id) }));
}

const parliamentLabels: Record<string, string> = {
  represented: "Parliamentary",
  "not-represented": "Extra-parliamentary",
  unknown: "Unknown",
  "not-applicable": "Not applicable"
};

const governmentLabels: Record<string, string> = {
  "in-government": "In government",
  "supports-government": "Supports government",
  opposition: "Opposition",
  neutral: "Neutral",
  mixed: "Mixed",
  unknown: "Unknown",
  "not-applicable": "Not applicable"
};

const legacyGovernmentMap: Record<string, string> = {
  government: "in-government",
  opposition: "opposition",
  mixed: "mixed",
  unknown: "unknown",
  "not-applicable": "not-applicable"
};

const parliament =
  party.representation?.parliament ??
  (
    party.governmentStatus?.label === "extra-parliamentary"
      ? {
          status: "not-represented",
          since: party.governmentStatus.since,
          note: party.governmentStatus.description,
          sourceIds: party.governmentStatus.sourceIds ?? []
        }
      : null
  );

const legacyGovernmentStatus =
  party.governmentStatus &&
  legacyGovernmentMap[party.governmentStatus.label]
    ? {
        status: legacyGovernmentMap[party.governmentStatus.label],
        since: party.governmentStatus.since,
        note: party.governmentStatus.description,
        sourceIds: party.governmentStatus.sourceIds ?? []
      }
    : null;

const government =
  party.representation?.government ??
  legacyGovernmentStatus;

const socialMedia = [
  ...(party.links?.facebook
    ? [{ label: "Facebook", url: party.links.facebook, archiveUrl: null, sourceIds: [] }]
    : []),
  ...(party.links?.x
    ? [{ label: "X", url: party.links.x, archiveUrl: null, sourceIds: [] }]
    : []),
  ...(party.links?.instagram
    ? [{ label: "Instagram", url: party.links.instagram, archiveUrl: null, sourceIds: [] }]
    : []),
  ...(party.links?.youtube
    ? [{ label: "YouTube", url: party.links.youtube, archiveUrl: null, sourceIds: [] }]
    : []),
  ...(party.links?.socialMedia ?? []),
  ...(party.links?.other ?? []).map((link: any) => ({
    ...link,
    archiveUrl: null,
    sourceIds: []
  }))
];

const hexColors = (party.colors ?? []).filter(
  (color: unknown): color is string =>
    typeof color === "string" &&
    /^#(?:[0-9a-f]{3}|[0-9a-f]{6}|[0-9a-f]{8})$/i.test(color)
);

const primaryColor = hexColors[0] ?? null;
---

<aside
  class="infobox"
  style={primaryColor ? `--party-color: ${primaryColor};` : undefined}
>
  <header class="infobox-heading">
    <h2>{party.name.english}</h2>
    {party.name.native.length > 0 && (
      <p class="infobox-native-name">{party.name.native.join(" · ")}</p>
    )}
  </header>

  <img
    class="infobox-logo"
    src={assetPath(party.logo)}
    alt={`${party.name.english} logo`}
  />

  {party.name.abbreviation && (
    <p class="infobox-abbreviation">{party.name.abbreviation}</p>
  )}

  <dl>
    <div>
      <dt>Country</dt>
      <dd>
        <a href={withBase(`/countries/${party.country.id}/`)}>
          {party.country.name}
        </a>
      </dd>
    </div>

    <div>
      <dt>Status</dt>
      <dd class="infobox-status-stack">
        <span>{statusLabels[party.status]}</span>

        {parliament && (
          <span>
            {parliamentLabels[parliament.status] ?? parliament.status}
            {parliament.since && ` since ${formatDate(parliament.since)}`}
            {sourceLinks(parliament.sourceIds).map((source) => (
              <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
            ))}
          </span>
        )}

        {government && (
          <span>
            {governmentLabels[government.status] ?? government.status}
            {government.since && ` since ${formatDate(government.since)}`}
            {sourceLinks(government.sourceIds).map((source) => (
              <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
            ))}
          </span>
        )}
      </dd>
    </div>

    <div>
      <dt>Founded</dt>
      <dd>
        {formatDate(party.dates.founded.date)}
        {sourceLinks(party.dates.founded.sourceIds).map((source) => (
          <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
        ))}
      </dd>
    </div>

    {party.dates.registered?.date && (
      <div>
        <dt>Registered</dt>
        <dd>
          {formatDate(party.dates.registered.date)}
          {sourceLinks(party.dates.registered.sourceIds).map((source) => (
            <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
          ))}
        </dd>
      </div>
    )}

    {party.dates.dissolved?.date && (
      <div>
        <dt>Dissolved</dt>
        <dd>
          {formatDate(party.dates.dissolved.date)}
          {sourceLinks(party.dates.dissolved.sourceIds).map((source) => (
            <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
          ))}
        </dd>
      </div>
    )}

    {party.ideology.labels.length > 0 && (
      <div>
        <dt>Ideology</dt>
        <dd>
          <ul class="infobox-list">
            {party.ideology.labels.map((item: any) => (
              <li>
                {item.name}
                {sourceLinks(item.sourceIds).map((source) => (
                  <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
                ))}
              </li>
            ))}
          </ul>
        </dd>
      </div>
    )}

    {party.ideology.position?.label && (
      <div>
        <dt>Position</dt>
        <dd>
          {party.ideology.position.label}
          {sourceLinks(party.ideology.position.sourceIds).map((source) => (
            <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
          ))}
        </dd>
      </div>
    )}

    {party.internationalAffiliations.length > 0 && (
      <div>
        <dt>Supranational alliances</dt>
        <dd>
          <ul class="infobox-list">
            {party.internationalAffiliations.map((item: any) => (
              <li>
                {item.name}
                {item.status && <>{` – ${item.status}`}</>}
                {item.since && <>{` (since ${formatDate(item.since)})`}</>}
                {item.until && <>{` (until ${formatDate(item.until)})`}</>}
                {sourceLinks(item.sourceIds).map((source) => (
                  <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
                ))}
              </li>
            ))}
          </ul>
        </dd>
      </div>
    )}

    {hexColors.length > 0 && (
      <div>
        <dt>Colours</dt>
        <dd class="infobox-colors">
          {hexColors.map((color) => (
            <span class="infobox-color-item">
              <span
                class="infobox-color-dot"
                style={`background-color: ${color};`}
                aria-hidden="true"
              ></span>
              <code>{color.toUpperCase()}</code>
            </span>
          ))}
        </dd>
      </div>
    )}

    {(party.links?.website || party.links?.websiteArchive) && (
      <div>
        <dt>Website</dt>
        <dd class="infobox-link-stack">
          {party.links.website && (
            <a href={party.links.website} rel="external">Official website</a>
          )}
          {party.links.websiteArchive && (
            <a href={party.links.websiteArchive} rel="external">Archived version</a>
          )}
        </dd>
      </div>
    )}

    {socialMedia.length > 0 && (
      <div>
        <dt>Social media</dt>
        <dd>
          <ul class="infobox-list">
            {socialMedia.map((item: any) => (
              <li>
                <a href={item.url} rel="external">{item.label}</a>
                {item.archiveUrl && (
                  <> (<a href={item.archiveUrl} rel="external">archive</a>)</>
                )}
                {sourceLinks(item.sourceIds).map((source) => (
                  <> <a class="source-ref" href={`#source-${source.id}`}>[{source.label}]</a></>
                ))}
              </li>
            ))}
          </ul>
        </dd>
      </div>
    )}

    {party.lastUpdated && (
      <div>
        <dt>Last reviewed</dt>
        <dd>{party.lastUpdated}</dd>
      </div>
    )}
  </dl>
</aside>
