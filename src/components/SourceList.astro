---
interface Props {
  sources: any[];
}

const { sources } = Astro.props;
---

{sources.length === 0 ? (
  <p class="notice">No sources have been added to this demonstration entry.</p>
) : (
  <ol class="sources">
    {sources.map((source) => (
      <li id={`source-${source.id}`}>
        {source.author && <>{source.author}. </>}
        <cite>{source.title}</cite>
        {source.publisher && <>. {source.publisher}</>}
        {source.date && <> ({source.date})</>}
        {source.pages && <>, pp. {source.pages}</>}
        {source.url && <>. <a href={source.url} rel="external">Online source</a></>}
        {source.archiveUrl && <> · <a href={source.archiveUrl} rel="external">Archive</a></>}
        {source.accessed && <> (accessed {source.accessed})</>}
      </li>
    ))}
  </ol>
)}
