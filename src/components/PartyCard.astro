---
import { assetPath, withBase } from "../lib/paths";
import { statusLabels } from "../lib/format";

interface Props {
  party: any;
  entryId: string;
}

const { party, entryId } = Astro.props;
---

<article
  class="party-card"
  data-party-card
  data-search={[
    party.name.english,
    ...party.name.native,
    party.name.abbreviation ?? "",
    party.country.name,
    ...party.ideology.labels.map((item: any) => item.name),
    party.ideology.position?.label ?? ""
  ].join(" ").toLowerCase()}
  data-country={party.country.id}
  data-status={party.status}
>
  <a class="party-card-link" href={withBase(`/parties/${entryId}/`)}>
    <img
      class="party-logo"
      src={assetPath(party.logo)}
      alt=""
      width="72"
      height="72"
      loading="lazy"
    />
    <div>
      <p class="eyebrow">{party.country.name}</p>
      <h2>{party.name.english}</h2>
      {party.name.native.length > 0 && <p class="native-name">{party.name.native.join(" · ")}</p>}
      <div class="chips">
        <span class={`status status-${party.status}`}>{statusLabels[party.status]}</span>
        {party.ideology.position?.label && <span class="chip">{party.ideology.position.label}</span>}
      </div>
    </div>
  </a>
</article>
