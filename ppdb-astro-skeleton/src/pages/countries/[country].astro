---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PartyCard from "../../components/PartyCard.astro";

export async function getStaticPaths() {
  const entries = await getCollection("parties");
  const countries = new Map<string, { id: string; name: string }>();

  for (const entry of entries) {
    countries.set(entry.data.country.id, entry.data.country);
  }

  return [...countries.values()].map((country) => ({
    params: { country: country.id },
    props: { country }
  }));
}

const { country } = Astro.props;
const entries = await getCollection(
  "parties",
  ({ data }) => data.country.id === country.id
);
const parties = entries
  .map((entry) => ({ entryId: entry.id, ...entry.data }))
  .sort((a, b) => a.name.english.localeCompare(b.name.english));
---

<BaseLayout title={`${country.name} — Political Parties Database`}>
  <header class="page-header">
    <p class="eyebrow">Country</p>
    <h1>{country.name}</h1>
    <p class="lead">{parties.length} party entries.</p>
  </header>

  <div class="card-grid">
    {parties.map((party) => <PartyCard party={party} entryId={party.entryId} />)}
  </div>
</BaseLayout>
